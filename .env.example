# BackpackerMap runtime configuration.
# Copy to `.env` and fill in your own values. `.env` is gitignored.

# --- Required ---

# OpenRouteService API key. Free tier signup:
#   https://openrouteservice.org/dev/#/signup
# Free tier = 2,000 directions/day, 40 req/min.
ORS_API_KEY=

# --- Optional (defaults shown) ---

# Path to the AllTrails-exported GPX folder. Recursive globbing applies.
TRAILS_DIR=./data/trails

# Path to the Airbnb personal-data JSON export.
AIRBNB_EXPORT_PATH=./data/airbnb/personal_data.json

# Path to the Booking.com session cookies JSON (exported via Cookie-Editor).
BOOKING_COOKIES_PATH=./data/booking/cookies.json

# SQLite DB file. Created on first run.
DB_PATH=./db/backpackermap.sqlite

# HTTP server port.
PORT=3000
