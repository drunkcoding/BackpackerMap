# BackpackerMap runtime configuration.
# Copy to `.env` and fill in your own values. `.env` is gitignored.

# --- Required ---

# OpenRouteService API key. Free tier signup:
#   https://openrouteservice.org/dev/#/signup
# Free tier = 2,000 directions/day, 40 req/min.
ORS_API_KEY=

# --- Recommended ---

# Absolute path to Python 3.10+. pyairbnb uses match-statement syntax and
# will SyntaxError on Python <= 3.9 even though `pip install` succeeds.
# Leave blank to fall back to `python3` (Linux/macOS) or `python` (Windows)
# from PATH — only safe if your default Python is already 3.10+.
# PYTHON_BIN=/usr/bin/python3.10
PYTHON_BIN=

# --- Optional (defaults shown) ---

# Path to the AllTrails-exported GPX folder. Recursive globbing applies.
TRAILS_DIR=./data/trails

# Path to the Airbnb personal-data JSON export.
AIRBNB_EXPORT_PATH=./data/airbnb/personal_data.json

# Path to the Booking.com session cookies JSON (exported via Cookie-Editor).
BOOKING_COOKIES_PATH=./data/booking/cookies.json

# SQLite DB file. Created on first run.
DB_PATH=./db/backpackermap.sqlite

# HTTP server port. If you change this, also start Vite with
#   API_PORT=<port> npm --workspace web run dev
# so its /api proxy points to the right place.
PORT=3000

# --- Discover mode (v2) ---

# Comma-separated list of provider scopes to enable for /api/search.
# Valid values: airbnb, booking. Default = both.
# SEARCH_PROVIDERS=airbnb,booking

# Residential proxy for both pyairbnb subprocess and Booking Playwright session.
# Use when DataDome challenges direct requests (typically >~30 results/search).
# HTTPS_PROXY=http://user:pass@residential-proxy.example:8000
